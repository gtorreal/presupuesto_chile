# Shadow USDCLP - Environment Variables

# ── External API Keys ──────────────────────────────────────────────────────────

# Massive.com (ex-Polygon.io) - Plan Currencies $49/mo
# Provides: USDBRL, USDMXN, USDCOP via REST + WebSocket
MASSIVE_API_KEY=

# Twelve Data - Plan Pro $99/mo
# Provides: DXY, HG (Copper), VIX, TNX (US 10Y), ECH
TWELVEDATA_API_KEY=

# CMF Chile - Free, register at api.cmfchile.cl
CMF_API_KEY=

# Buda.com private endpoints (optional, public endpoints work without auth)
BUDA_API_KEY=
BUDA_API_SECRET=

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=shadow
POSTGRES_PASSWORD=shadow
POSTGRES_DB=shadow_usdclp
DATABASE_URL=postgresql://shadow:shadow@db:5432/shadow_usdclp

# ── Collector ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30
# Yahoo Finance polling interval (data updates every ~15min, so 300s is fine)
YFINANCE_POLL_INTERVAL_SECONDS=300

# ── Calculator ────────────────────────────────────────────────────────────────
SHADOW_CALC_INTERVAL_SECONDS=30
CONFIDENCE_K=2.0

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Autenticación ─────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
# Duración del token en horas
JWT_EXPIRE_HOURS=8
# Usuarios: usuario:contraseña, separados por coma para múltiples
# Ejemplo: AUTH_USERS=admin:pass1,analista:pass2
AUTH_USERS=admin:shadow

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
